# Kopiere diese Datei zu .env.local und trage die echten Werte ein.
# .env.local ist in .gitignore — Keys landen nie in Git.

# Supabase (Projekt-URL + Anon-Public-Key)
# zu finden in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: AI-Provider explizit ueberschreiben (default: gemini)
# VITE_AI_PROVIDER=gemini
